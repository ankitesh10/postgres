// selecting recipes with between 4 - 6 ingredients

SELECT r.title
FROM
 recipe_ingredients ri
INNER JOIN
 recipes r
ON
 ri.recipe_id = r.recipe_id
GROUP BY
 r.title
HAVING
 COUNT(r.title) BETWEEN 4 AND 6;



// with ingredients name
SELECT
  r.title AS recipe_title,
  STRING_AGG(i.title, ', ' ORDER BY i.title) AS ingredients
FROM recipe_ingredients ri
JOIN recipes r
  ON ri.recipe_id = r.recipe_id
JOIN ingredients i
  ON ri.ingredient_id = i.id
GROUP BY
  r.recipe_id, r.title
HAVING
  COUNT(*) BETWEEN 4 AND 6;



// with array aggregates
SELECT
  r.title AS recipe_title,
  ARRAY_AGG(i.title ORDER BY i.title) AS ingredients
FROM recipe_ingredients ri
JOIN recipes r
  ON ri.recipe_id = r.recipe_id
JOIN ingredients i
  ON ri.ingredient_id = i.id
GROUP BY
  r.recipe_id, r.title
HAVING
  COUNT(*) BETWEEN 4 AND 6;


// function
CREATE OR REPLACE FUNCTION
  get_recipes_with_ingredients(low INT, high INT)
RETURNS
  SETOF VARCHAR
LANGUAGE
  plpgsql
AS
$$
BEGIN
  RETURN QUERY SELECT
    r.title
  FROM
    recipe_ingredients ri

  INNER JOIN
    recipes r
  ON
    r.recipe_id = ri.recipe_id

  GROUP BY
    r.title
  HAVING
    COUNT(r.title) between low and high;
END;
$$;

// Now query it.

SELECT * FROM get_recipes_with_ingredients(2, 3);


