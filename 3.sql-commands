// insert Multiple
INSERT INTO ingredients (
    title, image, type
) VALUES (
    'red pepper', 'red_pepper.png', 'vegetable'
);

// always put single qoutes for values, double quotes can be use in indentifiers
INSERT INTO ingredients (
    "title", "image", type
) VALUES (
    'broccoli', 'broccoli.png', 'vegetable'
);



