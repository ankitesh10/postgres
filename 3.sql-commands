// UPSERT - update and insert in one step
INSERT INTO ingredients (
    title, image, type
) VALUES (
    'watermelon', 'banana.jpg', 'this won''t be updated') -- double single quote is used escape in sql
ON CONFLICT (title) DO UPDATE SET image = excluded.image; -- excluded means the row which got excluded, replace current image with that 


// read row
SELECT * FROM ingredients WHERE title='watermelon';

// update
UPDATE ingredients SET image = 'strawberry.jpg' WHERE title='watermelon';

// return 
UPDATE ingredients SET image = 'watermelon.jpg' 
WHERE title='watermelon' 
RETURNING title, image, id, type;

UPDATE ingredients SET image = 'watermelon.jpg' 
WHERE title='watermelon' 
RETURNING *;

// delete
INSERT INTO ingredients
  (title, image, type)
VALUES
  ('not real 1', 'delete.jpg', 'well'),
  ('not real 2', 'delete.jpg', 'well');

DELETE FROM ingredients 
WHERE image = 'delete.jpg'
RETURNING *;