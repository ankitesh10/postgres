CREATE TABLE recipes (
    recipe_id INT PRIMARY KEY GENERATED ALWAYS AS IDENTITY,
    title VARCHAR (255) UNIQUE NOT NULL,
    body TEXT
);

// TEXT has no bounds on number of characters, as recipe can be huge


