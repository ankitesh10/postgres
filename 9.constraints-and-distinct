// select first inamge for all reciepe photos
SELECT DISTINCT ON (r.recipe_id)
 r.recipe_id, r.title, r.body, COALESCE(rp.url, 'default.png') AS url
FROM
 recipes r
LEFT JOIN
 recipes_photos rp
ON
 r.recipe_id = rp.recipe_id;